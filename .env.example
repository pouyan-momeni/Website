# ALMPlatform Environment Configuration
# Copy to .env and fill in with your actual values

# Application mode: "develop" or "production"
APP_MODE=develop

# PostgreSQL (async + sync)
DATABASE_URL=postgresql+asyncpg://almplatform:CHANGE_ME@localhost:5432/almplatform
DATABASE_URL_SYNC=postgresql+psycopg2://almplatform:CHANGE_ME@localhost:5432/almplatform

# Redis
REDIS_URL=redis://localhost:6379/0

# LDAP
LDAP_URL=ldap://your-ldap-server:389
LDAP_BASE_DN=dc=yourcompany,dc=com

# JWT (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-key-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# SMTP for email notifications
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_FROM=almplatform@yourcompany.com

# File paths (adjust for your server)
SHARED_NAS_PATH=/mnt/nas/shared
RUNS_BASE_PATH=/data/almplatform/runs
ARCHIVE_BASE_PATH=/data/almplatform/archive
MARIMO_BASE_PATH=/data/almplatform/marimo

# Resource alerting thresholds
MEMORY_THRESHOLD=0.80
CPU_ALERT_THRESHOLD=0.90
ALERT_COOLDOWN_MINUTES=30

# App URL (used in email notification links)
APP_BASE_URL=http://your-server-hostname
